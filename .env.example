# ================================================
# GAK CRM — Environment Configuration
# Salin file ini jadi .env dan isi nilainya
# ================================================

APP_NAME="GAK CRM"
APP_ENV=production
APP_KEY=                          # Generate: php artisan key:generate
APP_DEBUG=false
APP_URL=https://your-app.railway.app

APP_LOCALE=id
APP_FALLBACK_LOCALE=en

# ================================================
# LOGGING
# ================================================
LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=error

# ================================================
# DATABASE — Supabase PostgreSQL
# Format: postgresql://postgres:[PASSWORD]@[HOST]:5432/postgres
# ================================================
DB_CONNECTION=pgsql
DB_HOST=                          # dari Supabase: Settings > Database > Host
DB_PORT=5432
DB_DATABASE=postgres
DB_USERNAME=postgres
DB_PASSWORD=                      # password Supabase project

# Wajib untuk koneksi Supabase dari luar
PGSSLMODE=require

# ================================================
# SESSION & CACHE
# ================================================
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

CACHE_STORE=database
QUEUE_CONNECTION=database
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# ================================================
# MAIL (opsional — untuk notifikasi email)
# ================================================
MAIL_MAILER=log
MAIL_FROM_ADDRESS="noreply@gak-crm.com"
MAIL_FROM_NAME="${APP_NAME}"

# ================================================
# VITE (frontend assets)
# ================================================
VITE_APP_NAME="${APP_NAME}"
